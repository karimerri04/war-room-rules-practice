            "java-incidents",
            "health"
          ]
        }
      }
    },
    {
      "name": "Find all Java incidents",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/java-incidents",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "java-incidents"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Response is an array', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Find Java incident by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/java-incidents/{{incidentId}}",
          "host": [
