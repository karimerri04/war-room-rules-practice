          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Incident id matches environment variable', function () { pm.expect(pm.response.json().id).to.eql(pm.environment.get('incidentId')); });"
            ]
          }
        }
      ]
