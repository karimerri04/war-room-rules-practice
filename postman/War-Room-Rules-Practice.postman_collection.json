            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Incident is INVESTIGATING', function () { pm.expect(pm.response.json().status).to.eql('INVESTIGATING'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Add investigation note",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"author\": \"Karim\",\n  \"message\": \"Checked repository contract and found missing Optional handling.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/java-incidents/{{incidentId}}/notes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "java-incidents",
            "{{incidentId}}",
            "notes"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Incident has at least one note', function () { pm.expect(pm.response.json().notes.length).to.be.greaterThan(0); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Resolve incident",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rootCause\": \"The repository did not represent absence explicitly.\",\n  \"resolution\": \"Use Optional in the repository contract and translate missing incidents to a 404 response.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/java-incidents/{{incidentId}}/resolve",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "java-incidents",
            "{{incidentId}}",
            "resolve"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('Incident is RESOLVED', function () { pm.expect(pm.response.json().status).to.eql('RESOLVED'); });"
            ]
          }
        }
      ]
    },
